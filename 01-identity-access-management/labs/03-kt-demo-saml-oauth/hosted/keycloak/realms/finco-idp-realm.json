{
  "realm": "finco-idp",
  "enabled": true,
  "displayName": "FinCo Corporate IdP (KT lab · hosted)",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "oauth2DeviceCodeLifespan": 600,
  "oauth2DevicePollingInterval": 5,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "roles": {
    "realm": [
      { "name": "iam-team", "description": "IAM engineering team" },
      { "name": "payments-read", "description": "Read-only access to payments data" },
      { "name": "payments-initiate", "description": "May initiate a payment (sensitive)" }
    ]
  },
  "groups": [
    { "name": "iam-engineers", "realmRoles": ["iam-team", "payments-read"] }
  ],
  "users": [
    {
      "id": "11111111-1111-1111-1111-111111111111",
      "username": "farhaan",
      "enabled": true,
      "emailVerified": true,
      "email": "farhaan@example.com",
      "firstName": "Farhaan",
      "lastName": "Ahmed",
      "credentials": [ { "type": "password", "value": "Passw0rd!", "temporary": false } ],
      "realmRoles": ["iam-team", "payments-read"],
      "groups": ["/iam-engineers"]
    },
    {
      "id": "22222222-2222-2222-2222-222222222222",
      "username": "priya",
      "enabled": true,
      "emailVerified": true,
      "email": "priya@example.com",
      "firstName": "Priya",
      "lastName": "Sharma",
      "credentials": [ { "type": "password", "value": "Passw0rd!", "temporary": false } ],
      "realmRoles": ["payments-read"]
    }
  ],
  "clients": [
    {
      "clientId": "kt-spa",
      "name": "OAuth — SPA (public, Auth Code + PKCE, OIDC)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["__CLIENT_ORIGIN__/*"],
      "webOrigins": ["__CLIENT_ORIGIN__", "+"],
      "fullScopeAllowed": true,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "__CLIENT_ORIGIN__/*"
      }
    },
    {
      "clientId": "kt-web",
      "name": "OAuth — Web app (confidential: Auth Code no-PKCE + Refresh + ROPC)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "kt-web-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["__CLIENT_ORIGIN__/*"],
      "webOrigins": ["+"],
      "fullScopeAllowed": true,
      "attributes": {}
    },
    {
      "clientId": "kt-service",
      "name": "OAuth — Service account (Client Credentials)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "kt-service-secret",
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": true
    },
    {
      "clientId": "kt-device",
      "name": "OAuth — Device (Device Authorization Grant)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": true,
      "attributes": { "oauth2.device.authorization.grant.enabled": "true" }
    },
    {
      "clientId": "kt-implicit",
      "name": "OAuth — Implicit (DEPRECATED, for contrast)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["__CLIENT_ORIGIN__/*"],
      "webOrigins": ["+"],
      "fullScopeAllowed": true
    },
    {
      "clientId": "kt-saml-broker",
      "name": "SAML — Service Provider (the app that trusts this IdP)",
      "enabled": true,
      "protocol": "saml",
      "frontchannelLogout": true,
      "redirectUris": [
        "__KC_ORIGIN__/realms/finco-app/broker/kc-idp/endpoint",
        "__KC_ORIGIN__/realms/finco-app/broker/kc-idp/endpoint/*"
      ],
      "attributes": {
        "saml.assertion.signature": "true",
        "saml.server.signature": "true",
        "saml.client.signature": "false",
        "saml.force.post.binding": "true",
        "saml.authnstatement": "true",
        "saml_name_id_format": "email",
        "saml_signature_canonicalization_method": "http://www.w3.org/2001/10/xml-exc-c14n#",
        "saml.signature.algorithm": "RSA_SHA256"
      },
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": { "user.attribute": "email", "friendly.name": "email", "attribute.name": "email", "attribute.nameformat": "Basic" }
        },
        {
          "name": "given name",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": { "user.attribute": "firstName", "friendly.name": "givenName", "attribute.name": "givenName", "attribute.nameformat": "Basic" }
        },
        {
          "name": "family name",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": { "user.attribute": "lastName", "friendly.name": "surname", "attribute.name": "surname", "attribute.nameformat": "Basic" }
        },
        {
          "name": "roles",
          "protocol": "saml",
          "protocolMapper": "saml-role-list-mapper",
          "consentRequired": false,
          "config": { "single": "true", "attribute.name": "Role", "attribute.nameformat": "Basic" }
        }
      ]
    },
    {
      "clientId": "kt-saml-app",
      "name": "SAML Demo — real Service Provider (SP-init + IdP-init)",
      "description": "The client app acts as a SAML SP (node-saml). ACS = <client>/saml/acs. IdP-initiated SSO URL name = finco-sp.",
      "enabled": true,
      "protocol": "saml",
      "frontchannelLogout": true,
      "adminUrl": "__CLIENT_ORIGIN__/saml/acs",
      "redirectUris": ["__CLIENT_ORIGIN__/saml/acs"],
      "attributes": {
        "saml.assertion.signature": "true",
        "saml.server.signature": "true",
        "saml.client.signature": "false",
        "saml.force.post.binding": "true",
        "saml.authnstatement": "true",
        "saml_name_id_format": "email",
        "saml_idp_initiated_sso_url_name": "finco-sp",
        "saml_assertion_consumer_url_post": "__CLIENT_ORIGIN__/saml/acs",
        "saml_signature_canonicalization_method": "http://www.w3.org/2001/10/xml-exc-c14n#",
        "saml.signature.algorithm": "RSA_SHA256"
      },
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": { "user.attribute": "email", "friendly.name": "email", "attribute.name": "email", "attribute.nameformat": "Basic" }
        },
        {
          "name": "given name",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": { "user.attribute": "firstName", "friendly.name": "givenName", "attribute.name": "givenName", "attribute.nameformat": "Basic" }
        },
        {
          "name": "family name",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": { "user.attribute": "lastName", "friendly.name": "surname", "attribute.name": "surname", "attribute.nameformat": "Basic" }
        },
        {
          "name": "roles",
          "protocol": "saml",
          "protocolMapper": "saml-role-list-mapper",
          "consentRequired": false,
          "config": { "single": "true", "attribute.name": "Role", "attribute.nameformat": "Basic" }
        }
      ]
    }
  ]
}
