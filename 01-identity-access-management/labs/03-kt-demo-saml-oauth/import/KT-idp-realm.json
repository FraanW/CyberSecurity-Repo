{
  "realm": "KT-idp",
  "enabled": true,
  "displayName": "Fintech Corporate IdP (KT lab)",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "oauth2DeviceCodeLifespan": 600,
  "oauth2DevicePollingInterval": 5,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "roles": {
    "realm": [
      {
        "name": "iam-team",
        "description": "IAM engineering team"
      },
      {
        "name": "payments-read",
        "description": "Read-only access to payments data"
      },
      {
        "name": "payments-initiate",
        "description": "May initiate a payment (sensitive)"
      }
    ]
  },
  "groups": [
    {
      "name": "iam-engineers",
      "realmRoles": [
        "iam-team",
        "payments-read"
      ]
    }
  ],
  "users": [
    {
      "id": "11111111-1111-1111-1111-111111111111",
      "username": "farhaan",
      "enabled": true,
      "emailVerified": true,
      "email": "farhaan@example.com",
      "firstName": "Farhaan",
      "lastName": "Ahmed",
      "credentials": [
        {
          "type": "password",
          "value": "Passw0rd!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "iam-team",
        "payments-read"
      ],
      "groups": [
        "/iam-engineers"
      ]
    },
    {
      "id": "22222222-2222-2222-2222-222222222222",
      "username": "priya",
      "enabled": true,
      "emailVerified": true,
      "email": "priya@example.com",
      "firstName": "Priya",
      "lastName": "Sharma",
      "credentials": [
        {
          "type": "password",
          "value": "Passw0rd!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "payments-read"
      ]
    }
  ],
  "clients": [
    {
      "clientId": "kt-spa",
      "name": "OAuth Demo B — SPA (public, Auth Code + PKCE)",
      "description": "Public client for the browser SPA. No secret; protected by PKCE (S256).",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:9000/*"
      ],
      "webOrigins": [
        "http://localhost:9000",
        "+"
      ],
      "fullScopeAllowed": true,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:9000/*"
      }
    },
    {
      "clientId": "kt-web",
      "name": "OAuth Demo B/E — Web app (confidential, Auth Code + Refresh + ROPC)",
      "description": "Confidential client. Standard flow for the manual code exchange; direct-access enabled ONLY to demonstrate the deprecated ROPC grant.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "kt-web-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:9000/*",
        "http://localhost:9999/callback"
      ],
      "webOrigins": [
        "+"
      ],
      "fullScopeAllowed": true,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "kt-service",
      "name": "OAuth Demo C — Service account (Client Credentials)",
      "description": "Confidential machine-to-machine client. No user, no standard flow — only client_credentials.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "kt-service-secret",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "fullScopeAllowed": true
    },
    {
      "clientId": "kt-device",
      "name": "OAuth Demo D — Device (Device Authorization Grant)",
      "description": "Public client for input-constrained devices (smart TV / CLI). Device flow enabled.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "true"
      }
    },
    {
      "clientId": "kt-implicit",
      "name": "OAuth Demo — Implicit (DEPRECATED, for contrast)",
      "description": "Public client with the legacy Implicit flow enabled. Returns the token directly in the URL fragment — shown ONLY to demonstrate why it leaks and why OAuth 2.1 removed it.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:9000/*",
        "http://localhost:9999/callback"
      ],
      "webOrigins": [
        "+"
      ],
      "fullScopeAllowed": true
    },
    {
      "clientId": "kt-saml-broker",
      "name": "SAML Demo A — Service Provider (the app that trusts this IdP)",
      "description": "SAML SP registered here as a client. Entity ID = kt-saml-broker. The finco-app realm's SAML broker uses this identity. IdP signs assertions; SP AuthnRequest signing is off for lab simplicity.",
      "enabled": true,
      "protocol": "saml",
      "frontchannelLogout": true,
      "redirectUris": [
        "http://localhost:8080/realms/finco-app/broker/kc-idp/endpoint",
        "http://localhost:8080/realms/finco-app/broker/kc-idp/endpoint/*"
      ],
      "attributes": {
        "saml.assertion.signature": "true",
        "saml.server.signature": "true",
        "saml.client.signature": "false",
        "saml.force.post.binding": "true",
        "saml.authnstatement": "true",
        "saml_name_id_format": "email",
        "saml_signature_canonicalization_method": "http://www.w3.org/2001/10/xml-exc-c14n#",
        "saml.signature.algorithm": "RSA_SHA256"
      },
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "friendly.name": "email",
            "attribute.name": "email",
            "attribute.nameformat": "Basic"
          }
        },
        {
          "name": "given name",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "firstName",
            "friendly.name": "givenName",
            "attribute.name": "givenName",
            "attribute.nameformat": "Basic"
          }
        },
        {
          "name": "family name",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "lastName",
            "friendly.name": "surname",
            "attribute.name": "surname",
            "attribute.nameformat": "Basic"
          }
        },
        {
          "name": "roles",
          "protocol": "saml",
          "protocolMapper": "saml-role-list-mapper",
          "consentRequired": false,
          "config": {
            "single": "true",
            "attribute.name": "Role",
            "attribute.nameformat": "Basic"
          }
        }
      ]
    }
  ]
}