{
  "realm": "finco-app",
  "enabled": true,
  "displayName": "Fintech Expense App (KT lab · SAML Service Provider)",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "identityProviders": [
    {
      "alias": "kc-idp",
      "displayName": "Log in with Fintech Corporate IdP (SAML)",
      "providerId": "saml",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "singleSignOnServiceUrl": "http://localhost:8080/realms/KT-idp/protocol/saml",
        "singleLogoutServiceUrl": "http://localhost:8080/realms/KT-idp/protocol/saml",
        "idpEntityId": "http://localhost:8080/realms/KT-idp",
        "entityId": "kt-saml-broker",
        "nameIDPolicyFormat": "urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress",
        "principalType": "SUBJECT",
        "postBindingResponse": "true",
        "postBindingAuthnRequest": "true",
        "postBindingLogout": "true",
        "wantAssertionsSigned": "true",
        "wantAssertionsEncrypted": "false",
        "wantAuthnRequestsSigned": "false",
        "validateSignature": "false",
        "signatureAlgorithm": "RSA_SHA256",
        "syncMode": "IMPORT",
        "allowCreate": "true"
      }
    }
  ]
}